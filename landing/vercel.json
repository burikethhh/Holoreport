{
  "rewrites": [
    { "source": "/api/sync/receive", "destination": "/api/sync-receive" },
    { "source": "/api/sync/users", "destination": "/api/sync-users" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
